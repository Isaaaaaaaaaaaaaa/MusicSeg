const StatCard = ({ icon: Icon, label, value, trend, color }) => (
    <div className={`p-6 rounded-2xl border bg-white/50 dark:bg-white/5 backdrop-blur-md transition-all duration-500 hover:scale-[1.02] group ${
        color === 'blue' ? 'border-blue-200 dark:border-blue-500/20 hover:border-blue-400 dark:hover:border-blue-500/40 shadow-blue-500/5' :
        color === 'purple' ? 'border-purple-200 dark:border-purple-500/20 hover:border-purple-400 dark:hover:border-purple-500/40 shadow-purple-500/5' :
        color === 'green' ? 'border-green-200 dark:border-green-500/20 hover:border-green-400 dark:hover:border-green-500/40 shadow-green-500/5' :
        'border-orange-200 dark:border-orange-500/20 hover:border-orange-400 dark:hover:border-orange-500/40 shadow-orange-500/5'
